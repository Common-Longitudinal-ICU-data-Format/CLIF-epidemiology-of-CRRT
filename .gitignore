# R specific gitignores
# NOTE: .Rprofile is intentionally NOT ignored — it activates renv (source("renv/activate.R"))
# and must ship with the repo so every site auto-uses the pinned renv.lock library.
.Rhistory
.Ruserdata
.DS_Store
*.Rproj
.Rproj.user
*.egg-info
# renv: commit renv.lock + renv/activate.R + settings.json; ignore only the local library
# (renv/.gitignore already excludes renv/library/). Do NOT ignore all of renv/.
renv/library/
renv/local/
renv/staging/

## ignore the renv initialization file
initialize_renv.R

## ignore filtered CLIF tables stored as Rdata
*.RData

#ignore source CLIF_ files 
CLIF_*.parquet
CLIF_*.csv
CLIF_*.fst

#ignore the identifier app
CLIF_cohort_identifier*

# ignore file used to initialize renv when creating the template
initialize_renv.R

# ignore filtered CLIF tables stored as Rdata
*.RData

# ignore pdf reports and rendered html
*.pdf
*.html

.venv

# ignore Claude documentation files
claude.md
CLAUDE.md
.claude
.vscode/
.serena
context7.json

# directories
/reference
/app
/venv
.crrt/
/logs
/aggregate
/code_archive
__pycache__/
code/output/
/output/*
!/output/README.md
/output_mimic
/output_old
config/config_mimic.json
config/config_ucmc.json
config/config.json
output_ucmc/
docs/
all_site_data/
all_site_msm_data/
output/multi_site/
code/07_build_dashboard.py
code/08_manuscript_artifacts.py
code/report_core.py
code/archive/output/
code/archive/
